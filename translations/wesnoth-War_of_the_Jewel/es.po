#: War_of_the_Jewel/scenarios/23_A_Glimpse_Of_The_Light.cfg:55
#: War_of_the_Jewel/scenarios/24_The_Fires_Of_Shray_Tahl.cfg:137
#: War_of_the_Jewel/scenarios/25_Blazing_Hatred.cfg:90
#: War_of_the_Jewel/scenarios/26_Cradle_Of_Darkness.cfg:80
#: War_of_the_Jewel/scenarios/27_The_Folk_Of_The_Forest.cfg:82
#: War_of_the_Jewel/scenarios/28_Rain_Of_Light.cfg:77
#: War_of_the_Jewel/scenarios/29_From_Darkness.cfg:66
#: War_of_the_Jewel/scenarios/30_Renewing_Winds.cfg:61
#: War_of_the_Jewel/scenarios/31_Raging_Thunder.cfg:82
#: War_of_the_Jewel/scenarios/32_Light_Against_Light.cfg:72
#: War_of_the_Jewel/scenarios/33_Fiery_Souls.cfg:68
#: War_of_the_Jewel/scenarios/34_Fires_Of_Defiance.cfg:80
#: War_of_the_Jewel/scenarios/35_Crimson_Earth.cfg:85
#: War_of_the_Jewel/scenarios/36_Master_Of_Four_Lights.cfg:81
#: War_of_the_Jewel/scenarios/37_Forces_Of_Nature.cfg:39
#: War_of_the_Jewel/scenarios/38_Winds_Of_Fate.cfg:22
#: War_of_the_Jewel/scenarios/Epilogue_WotJ.cfg:20
msgid "Maat'Karian Rebels"
msgstr "Rebeldes Maat'Karianos"

#. [side]
#: War_of_the_Jewel/scenarios/14_Frozen_Earth_b.cfg:76
msgid "Monsters"
msgstr "Monstruos"

#. [side]
#: War_of_the_Jewel/scenarios/14_Frozen_Earth_b.cfg:92
#: War_of_the_Jewel/scenarios/14_Frozen_Earth_b.cfg:109
#: War_of_the_Jewel/scenarios/14_Frozen_Earth_b.cfg:126
#: War_of_the_Jewel/scenarios/14_Frozen_Earth_b.cfg:142
#: War_of_the_Jewel/scenarios/14_Frozen_Earth_b.cfg:159
msgid "Dead Line"
msgstr "Línea Muerta"

#. [message], speaker=unit
#: War_of_the_Jewel/scenarios/14_Frozen_Earth_b.cfg:211
#: War_of_the_Jewel/scenarios/16_Burning_Ice.cfg:151
msgid "Should I take this amulet?"
msgstr "¿Debería tomar este amuleto?"

#. [option]
#: War_of_the_Jewel/scenarios/14_Frozen_Earth_b.cfg:213
#: War_of_the_Jewel/scenarios/16_Burning_Ice.cfg:153
msgid "Yes, I'll take it."
msgstr "Sí, lo tomaré."

#. [object]
#: War_of_the_Jewel/scenarios/14_Frozen_Earth_b.cfg:218
#: War_of_the_Jewel/scenarios/16_Burning_Ice.cfg:158
msgid "Flameheart Amulet"
msgstr "Amuleto de Corazón de Llama"

#. [object]
#: War_of_the_Jewel/scenarios/14_Frozen_Earth_b.cfg:220
#: War_of_the_Jewel/scenarios/16_Burning_Ice.cfg:160
msgid "This unit is protected from freezing during this scenario."
msgstr "Esta unidad está protegida de la congelación durante este escenario."

#. [option]
#: War_of_the_Jewel/scenarios/14_Frozen_Earth_b.cfg:248
#: War_of_the_Jewel/scenarios/16_Burning_Ice.cfg:188
msgid "No, I think someone else should wear it."
msgstr "No, creo que algún otro debería llevarlo."

#. [effect], apply_to=new_attack, type=pierce, range=melee
#: War_of_the_Jewel/scenarios/14_Frozen_Earth_b.cfg:351
msgid "Trident of the Seas"
msgstr "Tridente de los Mares"

#. [message], speaker=Merwe
#: War_of_the_Jewel/scenarios/14_Frozen_Earth_b.cfg:409
msgid ""
"Akhen, your ancestor did not exaggerate when he said that even one's lungs "
"freeze if one breathes this land's air for too long. The Windsong couldn't "
"have picked a better place to hide: I doubt that any nation would dare "
"attack them here, though I also wonder how they manage to survive in this "
"frozen desert."
msgstr ""
"Akhen, tu ancestro no exageró cuando dijo que incluso los pulmones se "
"congelan si se respira el aire de esta tierra por demasiado tiempo. Las "
"Hijas del Viento no podrían haber elegido un mejor lugar para esconderse: "
"dudo que alguna nación se atreva a atacarlas aquí, aunque también me "
"pregunto cómo logran sobrevivir en este desierto congelado."

#. [message], speaker=Nyx
#: War_of_the_Jewel/scenarios/14_Frozen_Earth_b.cfg:413
msgid ""
"You humans are so cute with all your frailty... Well, Nyx cannot complain, "
"this weather is so much gentler to her than that scorching hell you call the "
"Land's End peninsula."
msgstr ""
"Los humanos son tan lindos con toda su fragilidad... Bueno, Nyx no puede "
"quejarse, este clima es mucho más amable con ella que ese infierno abrasador "
"que ustedes llaman la península del Fin de la Tierra."

#. [message], speaker=Akhen
#: War_of_the_Jewel/scenarios/14_Frozen_Earth_b.cfg:417
msgid ""
"Atenak didn't leave us unaided in that, she prepared us three flameheart "
"amulets that will protect us from frostbite; a pity she couldn't prepare "
"more, we left Ineb-Hedj in such a hurry... Nevertheless, we won't suffer for "
"long in the cold if we find the Windsong as soon as we can, so we should "
"start moving already."
msgstr ""
"Atenak no nos dejó sin ayuda en eso, nos preparó tres amuletos de corazón de "
"llama que nos protegerán de la congelación; lástima que no pudo preparar "
"más, salimos de Ineb-Hedj con tanta prisa... Sin embargo, no sufriremos "
"mucho en el frío si encontramos a las Hijas del Viento lo antes posible, así "
"que ya deberíamos ponernos en marcha."

#. [message], speaker=Mahyus
#: War_of_the_Jewel/scenarios/14_Frozen_Earth_b.cfg:421
msgid ""
"You and Merwe should wear these amulets, Akhen; I'm protected by my Umbra "
"powers, and Nyx obviously doesn't feel anything, as do my undead and your "
"elementals."
msgstr ""
"Tú y Merwe deberían usar estos amuletos, Akhen; yo estoy protegido por mis "
"poderes de Umbra, y Nyx obviamente no siente nada, al igual que mis no-"
"muertos y tus elementales."

#. [message], speaker=Nyx
#: War_of_the_Jewel/scenarios/14_Frozen_Earth_b.cfg:425
msgid ""
"Now that was callous, Mahyus; I'm not so unfeeling, you know, I do have a "
"heart, even though it beats some ten times slower than your human ones..."
msgstr ""
"Eso fue cruel, Mahyus; no soy tan insensible, sabes, sí tengo un corazón, "
"aunque late unas diez veces más lento que los de ustedes los humanos..."

#. [message], speaker=Akhen
#: War_of_the_Jewel/scenarios/14_Frozen_Earth_b.cfg:429
msgid ""
"This is no time for jokes, the survival of our people depends on our "
"mission! Don't forget that every second we fail to find allies for the "
"rebels is another second that the Sky Dragon controls Master Menon and all "
"of Maat'Kare!"
msgstr ""
"Este no es momento para bromas, ¡la supervivencia de nuestra gente depende "
"de nuestra misión! No olviden que cada segundo que no encontramos aliados "
"para los rebeldes es otro segundo que el Dragón del Cielo controla al "
"maestro Menon y a toda Maat'Kare."

#. [message], speaker=Nyx
#: War_of_the_Jewel/scenarios/14_Frozen_Earth_b.cfg:433
msgid "As you say, commander..."
msgstr "Como digas, comandante..."

#. [message], speaker=narrator
#: War_of_the_Jewel/scenarios/14_Frozen_Earth_b.cfg:438
msgid ""
"After fighting in the war on Netjer-Ta, Akhen, Merwe and Mahyus are "
"physically stronger, and so they move more quickly on snowy and sandy "
"terrains. Nyx, by her turn, moves even faster on these terrains."
msgstr ""
"Después de luchar en la guerra en Netjer-Ta, Akhen, Merwe y Mahyus son "
"físicamente más fuertes y por eso se mueven más rápido en terrenos nevados y "
"arenosos. Nyx, por su parte, se mueve aún más rápido en estos terrenos."

#. [message], speaker=unit
#: War_of_the_Jewel/scenarios/14_Frozen_Earth_b.cfg:459
msgid ""
"Look, there's a castle ahead; by its architecture, it must be a Windsong "
"one! Watch out, though, I can see some large beings dwelling there..."
msgstr ""
"Miren, hay un castillo adelante; por su arquitectura debe ser uno de las "
"Hijas del Viento. Cuidado, sin embargo, veo algunos seres grandes viviendo "
"allí..."

#. [message], speaker=Nyx
#: War_of_the_Jewel/scenarios/14_Frozen_Earth_b.cfg:470
msgid ""
"I recognize their smell, they're yetis... well, we should have expected to "
"find lots of them here, this Blue Realm is probably their original homeland."
msgstr ""
"Reconozco su olor, son yetis... bueno, deberíamos haber esperado encontrar "
"muchos de ellos aquí, este Reino Azul probablemente sea su tierra natal "
"original."

#. [message], speaker=Akhen
#: War_of_the_Jewel/scenarios/14_Frozen_Earth_b.cfg:474
msgid ""
"They may be large, but they can be taken down just as any creature: just "
"attack them in great numbers, and with your strongest attacks, and let's "
"clean that old fortress. It will shelter us from the blizzard, and we may "
"even find traces there that will lead us to the whereabouts of the "
"Windsong's Foundation in this land."
msgstr ""
"Pueden ser grandes, pero pueden ser derribados como cualquier criatura: solo "
"atáquenlos en gran número y con sus ataques más fuertes, y limpiemos esa "
"vieja fortaleza. Nos protegerá de la ventisca y quizás incluso encontremos "
"pistas allí que nos lleven al paradero de la Fundación de las Hijas del "
"Viento en esta tierra."

#. [message], speaker=Merwe
#: War_of_the_Jewel/scenarios/14_Frozen_Earth_b.cfg:512
msgid ""
"(shaking head) To kill such beautiful creatures without provocation... I "
"hope that fighting against monsters does not turn us into something similar."
msgstr ""
"(sacudiendo la cabeza) Matar a criaturas tan hermosas sin provocación... "
"Espero que luchar contra monstruos no nos convierta en algo similar."

#. [message], speaker=Akhen
#: War_of_the_Jewel/scenarios/14_Frozen_Earth_b.cfg:516
msgid "I too feel bad for that, but that was... Wait, what was that noise...?"
msgstr ""
"Yo también me siento mal por eso, pero eso fue... Espera, ¿qué fue ese "
"ruido...?"

#. [message], speaker=Nyx
#: War_of_the_Jewel/scenarios/14_Frozen_Earth_b.cfg:520
msgid "There's someone hidden beneath the rubble!"
msgstr "¡Hay alguien escondido debajo de los escombros!"

#. [message], speaker=Yukia
#: War_of_the_Jewel/scenarios/14_Frozen_Earth_b.cfg:536
msgid ""
"Aaaaaahhhh!!! Damn you, vile vampire, release Yukia at once, or you shall "
"regret it dearly! Yukia could cause a fire cipher to explode at point blank "
"in your face, or put garlic right into your nostrils, or cast a spell that "
"you turn my blood into poison..."
msgstr ""
"¡Aaaaaahhhh!!! ¡Maldito vampiro vil, suelta a Yukia de inmediato o lo "
"lamentarás mucho! Yukia podría hacer explotar un cifrado de fuego a "
"quemarropa en tu cara, o meter ajo directamente en tus fosas nasales, o "
"lanzar un hechizo que convierta mi sangre en veneno..."

#. [message], speaker=Nyx
#: War_of_the_Jewel/scenarios/14_Frozen_Earth_b.cfg:540
msgid ""
"So this is what you call 'Windsong'? My, my, they're noisy little creatures, "
"aren't they..."
msgstr ""
"¿Así que esto es lo que llaman «Hijas del Viento»? Vaya, vaya, son criaturas "
"ruidosas y pequeñas, ¿verdad...?"

#. [message], speaker=Akhen
#: War_of_the_Jewel/scenarios/14_Frozen_Earth_b.cfg:544
msgid ""
"Windsong, calm down, for we wish you no harm. My name is Akhen Wadjet, "
"descendant of Myra of Hiera'Shirsha, and I come here to seek the aid of your "
"Order to vanquish the Foe of our ancestors."
msgstr ""
"Hija del Viento, cálmate, porque no te deseamos ningún daño. Mi nombre es "
"Akhen Wadjet, descendiente de Myra de Hiera'Shirsha, y vengo aquí a buscar "
"la ayuda de su Orden para vencer al Enemigo de nuestros ancestros."

#. [message], speaker=Yukia
#: War_of_the_Jewel/scenarios/14_Frozen_Earth_b.cfg:548
msgid ""
"(agape) You're an heir of Myra...? (sulking) You may have her blood, but "
"you're not her; to Yukia you look just like another silly man from... (looks "
"at banners) Wait, you... Are you Maat'Karians?!"
msgstr ""
"(boquiabierta) ¿Eres un heredero de Myra...? (haciendo pucheros) Puedes "
"tener su sangre, pero no eres ella; para Yukia te ves como otro hombre tonto "
"de... (mira los estandartes) Espera, tú... ¡¿Son maat'karianos?!"

#. [message], speaker=Akhen
#: War_of_the_Jewel/scenarios/14_Frozen_Earth_b.cfg:552
msgid "We are, but..."
msgstr "Lo somos, pero..."

#. [message], speaker=Yukia
#: War_of_the_Jewel/scenarios/14_Frozen_Earth_b.cfg:556
msgid ""
"(sullen) So now we're <i>definitely</i> not helping you! Headmistress was "
"really right all the time: 'the day will come when the Maat'Karians will "
"come to us for help, and when this happens, we'll just say...'"
msgstr ""
"(malhumorada) ¡Así que ahora <i>definitivamente</i> no los ayudaremos! La "
"directora tenía razón todo el tiempo: «llegará el día en que los "
"maat'karianos vendrán a pedirnos ayuda, y cuando eso suceda, simplemente "
"diremos...»"

#. [message], speaker=Akhen
#: War_of_the_Jewel/scenarios/14_Frozen_Earth_b.cfg:560
msgid ""
"'...we're not allowed to return to Netjer-Ta', yes, I know the story, but "
"tell me, would this stance remain unchanged if I told you that you could "
"have your revenge on Menon Hekare, the man who expelled you from that "
"continent?"
msgstr ""
"«...no se nos permite regresar a Netjer-Ta», sí, conozco la historia, pero "
"dime, ¿esta postura seguiría igual si te dijera que podrían vengarse de "
"Menon Hekare, el hombre que las expulsó de ese continente?"

#. [message], speaker=Yukia
#: War_of_the_Jewel/scenarios/14_Frozen_Earth_b.cfg:564
msgid ""
"Um, weeeell... Um, I think only Headmistress could answer that question... "
"(suddenly angry) But I've told you already, I'm not letting you into our "
"holy Order, so give up trying!"
msgstr ""
"Um, buuueno... Um, creo que solo la directora podría responder esa "
"pregunta... (de repente enojada) ¡Pero ya te dije que no los dejaré entrar a "
"nuestra sagrada Orden, así que deja de intentarlo!"

#. [message], speaker=Akhen
#: War_of_the_Jewel/scenarios/14_Frozen_Earth_b.cfg:568
msgid "(impatient) Now you listen to me, you brat..."
msgstr "(impaciente) Ahora escúchame, mocosa..."

#. [message], speaker=Yukia
#: War_of_the_Jewel/scenarios/14_Frozen_Earth_b.cfg:572
msgid "Aiieeee!!! Don't hit Yukia, you brute!"
msgstr "¡Aiieeee!!! ¡No golpees a Yukia, bruto!"

#. [message], speaker=Akhen
#: War_of_the_Jewel/scenarios/14_Frozen_Earth_b.cfg:576
msgid ""
"...you would probably have been reduced to icy human sauce now had we not "
"saved you, and if we left you alone you'll probably be caught again by other "
"yetis, so you're going to be a nice girl and escort us to your Foundation, "
"did you understand?"
msgstr ""
"...probablemente ya te habrían convertido en salsa humana helada si no te "
"hubiéramos salvado, y si te dejamos sola probablemente te atrapen de nuevo "
"otros yetis, así que vas a ser una buena niña y nos escoltarás hasta tu "
"Fundación, ¿entendiste?"

#. [message], speaker=Yukia
#: War_of_the_Jewel/scenarios/14_Frozen_Earth_b.cfg:580
msgid "NEVER!!! (sticks tongue at him)"
msgstr "¡NUNCA!!! (le saca la lengua)"

#. [message], speaker=Merwe
#: War_of_the_Jewel/scenarios/14_Frozen_Earth_b.cfg:584
msgid ""
"(calmly) Listen, Yukia, we just want help in defeating the Sky Dragon. Do "
"you know what will happen if he wins? Doom and destruction all over Irdya, "
"all of civilization vanishing forever, and the Windsong will probably be the "
"ones who'll suffer the most, because two of your Heads have been responsible "
"for his defeat in the past. Do you wish it to happen, Yukia? Do you wish to "
"see your home being burned and your sisters being chewed like gum by the Sky "
"Dragon, their bowels dangling from his bloody jaws..."
msgstr ""
"(con calma) Escucha, Yukia, solo queremos ayuda para derrotar al Dragón del "
"Cielo. ¿Sabes qué pasará si gana? Condena y destrucción por toda Irdya, toda "
"la civilización desaparecerá para siempre, y las Hijas del Viento "
"probablemente serán las que más sufran, porque dos de tus Cabezas han sido "
"responsables de su derrota en el pasado. ¿Deseas que eso ocurra, Yukia? "
"¿Quieres ver tu hogar arder y a tus hermanas siendo masticadas como chicle "
"por el Dragón del Cielo, con sus entrañas colgando de sus fauces "
"ensangrentadas..."

#. [message], speaker=Yukia
#: War_of_the_Jewel/scenarios/14_Frozen_Earth_b.cfg:588
msgid ""
"(frightened) Stop, stop, stop! Ugh... All right, you've convinced me... I'll "
"show you where Hiera'Kyria stands, but only your leaders may enter it - and "
"don't even try to assault our Foundation! We've built an awful lot of traps "
"all around it, you won't even be able to..."
msgstr ""
"(asustada) ¡Detente, detente, detente! Ugh... De acuerdo, me convencieron... "
"Les mostraré dónde está Hiera'Kyria, pero solo sus líderes pueden entrar, ¡y "
"ni intenten asaltar nuestra Fundación! Hemos construido muchísimas trampas "
"alrededor, ni siquiera podrán..."

#. [message], speaker=Akhen
#: War_of_the_Jewel/scenarios/14_Frozen_Earth_b.cfg:592
msgid "All right, we got that. So, where should we go now?"
msgstr "De acuerdo, entendido. Entonces, ¿adónde debemos ir ahora?"

#. [message], speaker=Yukia
#: War_of_the_Jewel/scenarios/14_Frozen_Earth_b.cfg:596
msgid ""
"We must cross the Crystal Mountains - that range to the north - and keep "
"going north along the Howling Rifts, thus we'll inevitably reach "
"Hiera'Kyria. Ah, and watch out for more yetis at the mountains."
msgstr ""
"Debemos cruzar las Montañas de Cristal, esa cadena al norte, y seguir hacia "
"el norte a lo largo de las Grietas Aullantes, así llegaremos sin falta a "
"Hiera'Kyria. Ah, y tengan cuidado con más yetis en las montañas."

#. [objective], condition=win
#: War_of_the_Jewel/scenarios/14_Frozen_Earth_b.cfg:602
msgid "Reach the northern edge of the map with Akhen, Merwe, Mahyus or Nyx"
msgstr "Llega al borde norte del mapa con Akhen, Merwe, Mahyus o Nyx"

#. [objective], condition=lose
#: War_of_the_Jewel/scenarios/14_Frozen_Earth_b.cfg:622
#: War_of_the_Jewel/scenarios/16_Burning_Ice.cfg:43
msgid "Death of Yukia"
msgstr "Muerte de Yukia"

#. [message], speaker=Merwe
#: War_of_the_Jewel/scenarios/14_Frozen_Earth_b.cfg:656
msgid ""
"Am I the only one who's noticed that Yukia speaks just like Nyx, referring "
"to herself in third person and all? One could even say that they're mother "
"and daughter..."
msgstr ""
"¿Soy la única que se ha dado cuenta de que Yukia habla igual que Nyx, "
"refiriéndose a sí misma en tercera persona y todo? Hasta se podría decir que "
"son madre e hija..."

#. [message], speaker=Nyx
#: War_of_the_Jewel/scenarios/14_Frozen_Earth_b.cfg:660
msgid ""
"Pff, as if elegant and refined Nyx would ever spawn such noisy little brat..."
msgstr ""
"Pff, como si la elegante y refinada Nyx fuera a engendrar a una mocosa "
"ruidosa como esta..."

#. [message], speaker=Yukia
#: War_of_the_Jewel/scenarios/14_Frozen_Earth_b.cfg:664
msgid ""
"I don't usually speak like that, only when I'm very nervous, so no, there's "
"nothing in me that can be compared to this blood-crazed, unclean undead..."
msgstr ""
"Normalmente no hablo así, solo cuando estoy muy nerviosa, así que no, no hay "
"nada en mí que se pueda comparar con esta sucia no-muerta sedienta de "
"sangre..."

#. [message], speaker=Nyx
#: War_of_the_Jewel/scenarios/14_Frozen_Earth_b.cfg:668
msgid "(stung) Tsc..."
msgstr "(ofendida) Tsc..."

#. [message], speaker=Merwe
#: War_of_the_Jewel/scenarios/14_Frozen_Earth_b.cfg:759
msgid ""
"(sigh) Just when I thought that this gods-forsaken land could at least be "
"free of these pesky monsters... Really, is there nowhere on Irdya that isn't "
"plagued by them?"
msgstr ""
"(suspiro) Justo cuando pensaba que esta tierra olvidada por los dioses al "
"menos estaría libre de estos molestos monstruos... ¿De verdad no hay ningún "
"lugar en Irdya que no esté plagado por ellos?"

#. [message], speaker=Yukia
#: War_of_the_Jewel/scenarios/14_Frozen_Earth_b.cfg:763
msgid "I agree that they're disgusting, but they can be quite handy..."
msgstr "Coincido en que son asquerosos, pero pueden ser bastante útiles..."

#. [message], speaker=Yukia
#: War_of_the_Jewel/scenarios/14_Frozen_Earth_b.cfg:771
msgid ""
"These undead were set by us Windsong. They're summoned from castles by "
"undead generals we've picked all over the world and put under our control "
"with spells from the Book of the Dead. These castles surround the land where "
"Hiera'Kyria stands, forming what we call the Dead Line; we'll have a hard "
"time crossing them..."
msgstr ""
"Estos no-muertos fueron colocados por nosotras las Hijas del Viento. Son "
"invocados desde castillos por generales no-muertos que hemos reclutado por "
"todo el mundo y puesto bajo nuestro control con hechizos del Libro de los "
"Muertos. Estos castillos rodean la tierra donde se encuentra Hiera'Kyria, "
"formando lo que llamamos la Línea Muerta; tendremos dificultades para "
"cruzarlos..."

#. [message], speaker=Nyx
#: War_of_the_Jewel/scenarios/14_Frozen_Earth_b.cfg:775
msgid ""
"Can't you, being a Windsong, make them stop somehow? And why didn't you "
"mention them before, you wicked brat?"
msgstr ""
"¿No puedes tú, siendo una Hija del Viento, hacer que se detengan de alguna "
"forma? ¿Y por qué no los mencionaste antes, mocosa malvada?"

#. [message], speaker=Yukia
#: War_of_the_Jewel/scenarios/14_Frozen_Earth_b.cfg:779
msgid ""
"Hey, stop calling me bad names, I just got nervous with all your brutality "
"and forgot about them, all right? And no, I don't know how to stop them; "
"there is a spell for that, but that's unknown to me."
msgstr ""
"Oye, deja de llamarme con nombres feos, solo me puse nerviosa con toda tu "
"brutalidad y me olvidé de ellos, ¿de acuerdo? Y no, no sé cómo detenerlos; "
"existe un hechizo para eso, pero yo no lo conozco."

#. [message], speaker=Merwe
#: War_of_the_Jewel/scenarios/14_Frozen_Earth_b.cfg:783
msgid ""
"All right, then, let us reduce them to ashes at once; we're quite proficient "
"at beating undead already..."
msgstr ""
"De acuerdo entonces, reduzcámoslos a cenizas de una vez; ya somos bastante "
"hábiles para derrotar no-muertos..."

#. [message], speaker=Yukia
#: War_of_the_Jewel/scenarios/14_Frozen_Earth_b.cfg:798
msgid ""
"Wow, you've really made it past the Dead Line alive! You're probably the "
"first ones to manage the deed in centuries, I have to congratulate you!"
msgstr ""
"¡Vaya, realmente lograron cruzar la Línea Muerta con vida! Probablemente "
"sean los primeros en lograrlo en siglos, ¡tengo que felicitarlos!"

#. [message], speaker=Nyx
#: War_of_the_Jewel/scenarios/14_Frozen_Earth_b.cfg:802
msgid ""
"You sound like you expected us to perish at the hands of your undead "
"lackeys..."
msgstr ""
"Suenas como si esperaras que pereciéramos a manos de tus lacayos no-"
"muertos..."

#. [message], speaker=Akhen
#: War_of_the_Jewel/scenarios/14_Frozen_Earth_b.cfg:806
msgid ""
"Certainly she did, though in her defence I can say that, in her place, we'd "
"have probably done the same. But now you're going to lead us straight to "
"Hiera'Kyria - and, if you try any funny trick on us, it will be 'dead line' "
"for you, do you get it?"
msgstr ""
"Claro que sí, aunque en su defensa puedo decir que, en su lugar, "
"probablemente habríamos hecho lo mismo. Pero ahora nos vas a llevar directo "
"a Hiera'Kyria, y si intentas alguna treta con nosotros, será «línea muerta» "
"para ti, ¿entendido?"

#. [message], speaker=Yukia
#: War_of_the_Jewel/scenarios/14_Frozen_Earth_b.cfg:810
msgid ""
"A-all right, Yukia's taking you to us Windsong's Foundation in a blink..."
msgstr ""
"D-de acuerdo, Yukia los llevará a la Fundación de las Hijas del Viento en un "
"abrir y cerrar de ojos..."

#. [message], speaker=Yukia
#: War_of_the_Jewel/scenarios/14_Frozen_Earth_b.cfg:829
#: War_of_the_Jewel/scenarios/16_Burning_Ice.cfg:902
msgid "Aaaaaiieeeee...!!!"
msgstr "¡Aaaaaiieeeee...!!!"

#. [message], speaker=Akhen
#: War_of_the_Jewel/scenarios/14_Frozen_Earth_b.cfg:833
msgid ""
"Damn it, how could we let her die? And what is worse, now we've lost our "
"best chance to find Hiera'Kyria!"
msgstr ""
"¡Maldición, cómo pudimos dejarla morir! Y lo peor es que ahora hemos perdido "
"nuestra mejor oportunidad de encontrar Hiera'Kyria."

#. [message], speaker=Akhen
#: War_of_the_Jewel/scenarios/14_Frozen_Earth_b.cfg:844
msgid ""
"We're taking too much time to cross this ice desert, at this pace we'll all "
"freeze to death!"
msgstr ""
"Estamos tardando demasiado en cruzar este desierto de hielo, ¡a este ritmo "
"todos moriremos congelados!"

#. [scenario], id=16_Burning_Ice
#: War_of_the_Jewel/scenarios/16_Burning_Ice.cfg:4
msgid "Burning Ice"
msgstr "Hielo Ardiente"

#. [objective], condition=win
#: War_of_the_Jewel/scenarios/16_Burning_Ice.cfg:23
msgid "Defeat the Aragwaithi General Kalinyon"
msgstr "Derrota al general aragwaithi Kalinyon"

#. [objective], condition=lose
#: War_of_the_Jewel/scenarios/16_Burning_Ice.cfg:47
msgid "Death of Vappu"
msgstr "Muerte de Vappu"

#. [side], type=Aragwaith Ancient Banner
#: War_of_the_Jewel/scenarios/16_Burning_Ice.cfg:81
msgid "Kalinyon"
msgstr "Kalinyon"

#. [side], type=Aragwaith Ancient Banner
#: War_of_the_Jewel/scenarios/16_Burning_Ice.cfg:86
msgid "Aragwaithi"
msgstr "Aragwaithi"

#. [side]
#: War_of_the_Jewel/scenarios/16_Burning_Ice.cfg:111
msgid "Hiera'Kyria"
msgstr "Hiera'Kyria"

#. [message], speaker=Mahyus
#: War_of_the_Jewel/scenarios/16_Burning_Ice.cfg:265
msgid "Eh, seems like we're not the only ones visiting you Windsong..."
msgstr ""
"Eh, parece que no somos los únicos que visitamos a las Hijas del Viento..."

#. [message], speaker=Yukia
#: War_of_the_Jewel/scenarios/16_Burning_Ice.cfg:269
msgid ""
"Those are not visitors, those are Aragwaithi! They're always harassing our "
"outermost borders, but to be able to reach Hiera'Kyria itself..."
msgstr ""
"Esos no son visitantes, ¡son aragwaithi! Siempre están hostigando nuestras "
"fronteras más externas, pero llegar hasta la propia Hiera'Kyria..."

#. [message], speaker=Akhen
#: War_of_the_Jewel/scenarios/16_Burning_Ice.cfg:273
msgid ""
"That's troublesome; I planned on finding them and asking for their aid too, "
"but now..."
msgstr ""
"Eso es problemático; planeaba encontrarlos y pedirles ayuda también, pero "
"ahora..."

#. [message], speaker=Nyx
#: War_of_the_Jewel/scenarios/16_Burning_Ice.cfg:277
msgid ""
"I think we should help the Windsong. For all you have told me, they're "
"masters in the magic arts, and have a matchless knowledge of the world; this "
"means that they may know not only more possible allies, but also secret arts "
"capable of countering the magic of the likes of Sadjet, Atseger and Menon "
"himself."
msgstr ""
"Creo que deberíamos ayudar a las Hijas del Viento. Por todo lo que me han "
"contado, son maestras en las artes mágicas y tienen un conocimiento "
"incomparable del mundo; eso significa que pueden conocer no solo más aliados "
"posibles, sino también artes secretas capaces de contrarrestar la magia de "
"gente como Sadjet, Atseger y el propio Menon."

#. [message], speaker=Akhen
#: War_of_the_Jewel/scenarios/16_Burning_Ice.cfg:281
msgid ""
"Well thought... Let us aid the Windsong, then - but we must be careful with "
"the Aragwaithi; centuries may have passed since their apogee, but I don't "
"think that they've lost their prowess in war."
msgstr ""
"Bien pensado... Ayudemos entonces a las Hijas del Viento, pero debemos tener "
"cuidado con los aragwaithi; pueden haber pasado siglos desde su apogeo, pero "
"no creo que hayan perdido su destreza en la guerra."

#. [message], speaker=Yukia
#: War_of_the_Jewel/scenarios/16_Burning_Ice.cfg:306
msgid ""
"Hey vampiress... Thanks for that. These Aragwaithi are so numerous, if the "
"Maat'Karians had decided to turn on us as well, we probably wouldn't survive."
msgstr ""
"Oye, vampiresa... Gracias por eso. Estos aragwaithi son tan numerosos que si "
"los maat'karianos también hubieran decidido volverse contra nosotras, "
"probablemente no sobreviviríamos."

#. [message], speaker=Nyx
#: War_of_the_Jewel/scenarios/16_Burning_Ice.cfg:310
msgid "(blinking) No need to thank me, I was just defending our own interests."
msgstr ""
"(parpadeando) No hace falta que me agradezcas, solo estaba defendiendo "
"nuestros propios intereses."

#. [message], speaker=Akhen
#: War_of_the_Jewel/scenarios/16_Burning_Ice.cfg:319
msgid "Merwe, Mahyus, have you felt something weird in this region as well...?"
msgstr ""
"Merwe, Mahyus, ¿ustedes también han sentido algo extraño en esta región...?"

#. [message], speaker=Mahyus
#: War_of_the_Jewel/scenarios/16_Burning_Ice.cfg:323
msgid ""
"I did... Even though this valley is a barren wasteland, it feels impregnated "
"with such energy...… Have you felt like this in any other place?"
msgstr ""
"Yo sí... Aunque este valle es un páramo estéril, se siente impregnado de "
"tanta energía... ¿Han sentido algo así en algún otro lugar?"

#. [message], speaker=Merwe
#: War_of_the_Jewel/scenarios/16_Burning_Ice.cfg:327
msgid "Absolutely not; Yukia, do you know something about that?"
msgstr "Absolutamente no; Yukia, ¿sabes algo sobre eso?"

#. [message], speaker=Yukia
#: War_of_the_Jewel/scenarios/16_Burning_Ice.cfg:331
msgid ""
"No, but... Well, it must be something related to the Higher Mysteries which "
"only the highest-ranking amongst us are allowed to learn."
msgstr ""
"No, pero... Bueno, debe ser algo relacionado con los Misterios Superiores "
"que solo los de más alto rango entre nosotras podemos aprender."

#. [message], speaker=Akhen
#: War_of_the_Jewel/scenarios/16_Burning_Ice.cfg:335
msgid "I see.."
msgstr "Ya veo..."

#. [message], speaker=Akhen
#: War_of_the_Jewel/scenarios/16_Burning_Ice.cfg:349
msgid "(surprised) *Myra? Is that really you?*"
msgstr "(sorprendido) *¿Myra? ¿Realmente eres tú?*"

#. [message], speaker=narrator
#: War_of_the_Jewel/scenarios/16_Burning_Ice.cfg:354
msgid ""
"<i>Akhen, this place where you stand right now, it's a very special one... I "
"have no time to explain it to you right now, since we're in the middle of a "
"battle, so just trust me: if you go to a keep, you may summon full "
"elementals.</i>"
msgstr ""
"<i>Akhen, este lugar donde te encuentras ahora es muy especial... No tengo "
"tiempo para explicártelo ahora, ya que estamos en medio de una batalla, así "
"que solo confía en mí: si vas a un torreón, podrás invocar elementales "
"completos.</i>"

#. [message], speaker=Akhen
#: War_of_the_Jewel/scenarios/16_Burning_Ice.cfg:358
msgid "*What? But I've never...*"
msgstr "*¿Qué? Pero nunca he...*"

#. [message], speaker=narrator
#: War_of_the_Jewel/scenarios/16_Burning_Ice.cfg:363
msgid ""
"<i>...been to a place like this, yes; however, right now you may count not "
"only with your own power, but with that of the spirits of Nature themselves."
"</i>"
msgstr ""
"<i>...estado en un lugar como este, sí; sin embargo, ahora puedes contar no "
"solo con tu propio poder, sino con el de los espíritus de la Naturaleza "
"mismos.</i>"

#. [message], speaker=Akhen
#: War_of_the_Jewel/scenarios/16_Burning_Ice.cfg:367
msgid "*Wait... (sigh) Well, I think there's nothing to lose in trying...*"
msgstr ""
"*Espera... (suspiro) Bueno, creo que no hay nada que perder probando...*"

#. [message], speaker=Merwe
#: War_of_the_Jewel/scenarios/16_Burning_Ice.cfg:390
msgid ""
"(frowning) Erm, Akhen, you didn't tell us that you had learned to summon "
"fully developed elementals..."
msgstr ""
"(frunciendo el ceño) Erm, Akhen, no nos habías dicho que habías aprendido a "
"invocar elementales completamente desarrollados..."

#. [message], speaker=Akhen
#: War_of_the_Jewel/scenarios/16_Burning_Ice.cfg:394
msgid "That's because I hadn't! This is the first time I summon one!"
msgstr "¡Es porque no lo había hecho! ¡Esta es la primera vez que invoco uno!"

#. [message], speaker=Nyx
#: War_of_the_Jewel/scenarios/16_Burning_Ice.cfg:398
msgid ""
"Could it have anything to do with this region's strange energy that you were "
"talking about?"
msgstr ""
"¿Podría tener algo que ver con esa energía extraña de la región de la que "
"hablabas?"

#. [message], speaker=Mahyus
#: War_of_the_Jewel/scenarios/16_Burning_Ice.cfg:402
msgid "Certainly it does..."
msgstr "Seguro que sí..."

#. [message], speaker=Vappu
#: War_of_the_Jewel/scenarios/16_Burning_Ice.cfg:406
msgid "(smirks)"
msgstr "(sonríe con ironía)"

#. [message], speaker=Yukia
#: War_of_the_Jewel/scenarios/16_Burning_Ice.cfg:423
msgid ""
"Hi, Headmistress! Please, don't attack these Maat'Karians, they've come as "
"friends, and want to help us repel these Aragwaithi!"
msgstr ""
"¡Hola, directora! Por favor, no ataques a estos maat'karianos, han venido "
"como amigos y quieren ayudarnos a repeler a estos aragwaithi."

#. [message], speaker=Vappu
#: War_of_the_Jewel/scenarios/16_Burning_Ice.cfg:427
msgid ""
"That Yukia... She disappears from our sights for days, makes us think her "
"dead, and then she returns with such allies... I know not what your "
"intentions and objectives are, Maat'Karians, but if you reinforce us, I, "
"Vappu, Head of the Windsong, promise to give you shelter and means to cross "
"the Blue Realm in safety."
msgstr ""
"Esa Yukia... Desaparece de nuestra vista durante días, nos hace pensar que "
"está muerta y luego regresa con aliados como estos... No sé cuáles son sus "
"intenciones y objetivos, maat'karianos, pero si nos refuerzan, yo, Vappu, "
"directora de las Hijas del Viento, prometo darles refugio y medios para "
"cruzar el Reino Azul a salvo."

#. [message], speaker=Akhen
#: War_of_the_Jewel/scenarios/16_Burning_Ice.cfg:431
msgid ""
"And I, Akhen Wadjet, thank you for that, Lady Vappu. We came here to speak "
"with you, but this may wait, for now we must vanquish these Aragwaithi."
msgstr ""
"Y yo, Akhen Wadjet, te lo agradezco, lady Vappu. Vinimos aquí a hablar "
"contigo, pero eso puede esperar, porque ahora debemos derrotar a estos "
"aragwaithi."

#. [message], speaker=Kalinyon
#: War_of_the_Jewel/scenarios/16_Burning_Ice.cfg:435
msgid ""
"I don't know who you are or where you come from, strangers, but if you are "
"lowly enough to side with these dirty, treacherous child-snatchers, I shall "
"spare you no mercy. Aragwaithi, charge! This is the day when we shall rid "
"the world of the Windsong evil!"
msgstr ""
"No sé quiénes son ni de dónde vienen, extraños, pero si son tan viles como "
"para ponerse del lado de estas sucias y traicioneras secuestradoras de "
"niños, no les tendré ninguna misericordia. ¡Aragwaithi, carguen! ¡Este es el "
"día en que libraremos al mundo del mal de las Hijas del Viento!"

#. [message], speaker=Nyx
#: War_of_the_Jewel/scenarios/16_Burning_Ice.cfg:451
msgid ""
"Um, folks, you said that the Aragwaithi weren't adept of magic, right? "
"Because some of their women are casting fireballs just like our Atenak "
"does..."
msgstr ""
"Um, gente, dijeron que los aragwaithi no eran adeptos de la magia, ¿verdad? "
"Porque algunas de sus mujeres están lanzando bolas de fuego igual que "
"nuestra Atenak..."

#. [message], speaker=Merwe
#: War_of_the_Jewel/scenarios/16_Burning_Ice.cfg:455
msgid ""
"Well, our knowledge on them is outdated by sixteen centuries, so it's far "
"from precise."
msgstr ""
"Bueno, nuestro conocimiento sobre ellos está desactualizado por dieciséis "
"siglos, así que está lejos de ser preciso."

#. [message], speaker=Yukia
#: War_of_the_Jewel/scenarios/16_Burning_Ice.cfg:459
msgid ""
"If you wish to know, the Aragwaithi are now an isolationist nation living on "
"the far northern shores of the Great Continent. They don't have great cities "
"anymore, but they've developed a fire magic lore that originated from the "
"teachings of those Windsong who deserted our Order to join King Varthan of "
"Garet-Desh, after the fall of that kingdom."
msgstr ""
"Si quieren saberlo, los aragwaithi son ahora una nación aislacionista que "
"vive en las costas más lejanas del norte del Gran Continente. Ya no tienen "
"grandes ciudades, pero han desarrollado un conocimiento de magia de fuego "
"que se originó en las enseñanzas de aquellas Hijas del Viento que desertaron "
"de nuestra Orden para unirse al rey Varthan de Garet-Desh, después de la "
"caída de ese reino."

#. [message], speaker=Mahyus
#: War_of_the_Jewel/scenarios/16_Burning_Ice.cfg:463
msgid "And what about the Rod of Justice? Do they still keep it, after all?"
msgstr ""
"¿Y qué hay de la Vara de la Justicia? ¿Todavía la conservan, después de todo?"

#. [message], speaker=Yukia
#: War_of_the_Jewel/scenarios/16_Burning_Ice.cfg:467
msgid ""
"This we don't know for sure, but we’ve never sighted anything that could be "
"related to the descriptions we have of that artefact."
msgstr ""
"Eso no lo sabemos con certeza, pero nunca hemos visto nada que pudiera estar "
"relacionado con las descripciones que tenemos de ese artefacto."

#. [message], speaker=narrator
#: War_of_the_Jewel/scenarios/16_Burning_Ice.cfg:482
msgid ""
"'In Memory of the Sisters Who Died So That The Windsong Foundation at the "
"North Pole of Irdya Could Be Built'"
msgstr ""
"«En memoria de las hermanas que murieron para que la Fundación de las Hijas "
"del Viento en el Polo Norte de Irdya pudiera ser construida»"

#. [message], speaker=Kalinyon
#: War_of_the_Jewel/scenarios/16_Burning_Ice.cfg:495
msgid ""
"So... close... You have committed a great mistake by trusting the Windsong, "
"stranger... mark my words..."
msgstr ""
"Tan... cerca... Has cometido un gran error al confiar en las Hijas del "
"Viento, extraño... recuerda mis palabras..."

#. [message], speaker=Vappu
#: War_of_the_Jewel/scenarios/16_Burning_Ice.cfg:507
msgid ""
"Someone collect his corpse and that of his fallen soldiers; he has opened "
"quite a gap in the Dead Line, and so he must compensate for that. As for "
"you, Maat'Karians, you are allowed to enter Hiera'Kyria; I am truly curious "
"about the reason that has brought you here..."
msgstr ""
"Que alguien recoja su cadáver y el de sus soldados caídos; ha abierto una "
"brecha considerable en la Línea Muerta y por eso debe compensarlo. En cuanto "
"a ustedes, maat'karianos, se les permite entrar a Hiera'Kyria; tengo mucha "
"curiosidad por la razón que los ha traído aquí..."

#. [message], speaker=Merwe
#: War_of_the_Jewel/scenarios/16_Burning_Ice.cfg:511
msgid ""
"(whisper) By the Gods, she's really going to use the corpses of the "
"Aragwaithi to defend her own land..."
msgstr ""
"(susurro) Por los Dioses, realmente va a usar los cadáveres de los "
"aragwaithi para defender su propia tierra..."

#. [message], speaker=Akhen
#: War_of_the_Jewel/scenarios/16_Burning_Ice.cfg:515
msgid ""
"(whisper) I agree that it's disgusting, but we have neither the time to pity "
"those Aragwaithi, nor the luxury to be choosy with our allies. (normal "
"voice) Thank you for welcoming us, Lady Vappu..."
msgstr ""
"(susurro) Coincido en que es asqueroso, pero no tenemos ni el tiempo para "
"compadecer a esos aragwaithi, ni el lujo de ser selectivos con nuestros "
"aliados. (voz normal) Gracias por recibirnos, lady Vappu..."

#. [message], speaker=Yukia
#: War_of_the_Jewel/scenarios/16_Burning_Ice.cfg:519
msgid "Come, I'll lead you to the Polar Hall."
msgstr "Vengan, los llevaré al Salón Polar."

#. [message], speaker=Vappu
#: War_of_the_Jewel/scenarios/16_Burning_Ice.cfg:632
msgid ""
"You claimed to be an heir of Myra, young man... But think not that we shall "
"deem you a friend because of that; in the memory of the Windsong, Myra of "
"Maat'Kare is the woman who weakened our Order by allowing so many schisms "
"after Maat the Great's death - and also the founder of that accursed nation "
"that betrayed us."
msgstr ""
"Afirmas ser un heredero de Myra, joven... Pero no pienses que te "
"consideraremos amigo por eso; en la memoria de las Hijas del Viento, Myra de "
"Maat'Kare es la mujer que debilitó nuestra Orden al permitir tantos cismas "
"después de la muerte de Maat el Grande, y también la fundadora de esa nación "
"maldita que nos traicionó."

#. [message], speaker=Akhen
#: War_of_the_Jewel/scenarios/16_Burning_Ice.cfg:636
msgid ""
"With all due respect, I don't care in the least about what you think of my "
"ancestors or my country. I only expect your wisdom, for the danger that "
"threatens my people also threatens the whole Irdya, including your Order."
msgstr ""
"Con todo respeto, no me importa en lo más mínimo lo que piensen de mis "
"ancestros o de mi país. Solo espero su sabiduría, porque el peligro que "
"amenaza a mi gente también amenaza a toda Irdya, incluyendo su Orden."

#. [message], speaker=Vappu
#: War_of_the_Jewel/scenarios/16_Burning_Ice.cfg:640
msgid ""
"So it seems that you've come to request our aid for that country... Methinks "
"this threat you talk about is certainly huge, for you to believe we would "
"help you; at the very least, it must be something like a new rise of the Sky "
"Dragon."
msgstr ""
"Así que parece que han venido a pedir nuestra ayuda para ese país... Me "
"parece que esta amenaza de la que hablas debe ser ciertamente enorme para "
"que creas que los ayudaríamos; al menos debe ser algo como un nuevo "
"surgimiento del Dragón del Cielo."

#. [message], speaker=narrator
#: War_of_the_Jewel/scenarios/16_Burning_Ice.cfg:644
msgid "<i>(giggles from the Windsong)</i>"
msgstr "<i>(risitas de las Hijas del Viento)</i>"

#. [message], speaker=Akhen
#: War_of_the_Jewel/scenarios/16_Burning_Ice.cfg:648
msgid ""
"Funny of you to say that, Lady Vappu, for that is exactly the threat I'm "
"talking about."
msgstr ""
"Qué gracioso que digas eso, lady Vappu, porque esa es exactamente la amenaza "
"de la que estoy hablando."

#. [message], speaker=Vappu
#: War_of_the_Jewel/scenarios/16_Burning_Ice.cfg:656
msgid "...Say again?"
msgstr "...¿Cómo dijiste?"

#. [message], speaker=Akhen
#: War_of_the_Jewel/scenarios/16_Burning_Ice.cfg:660
msgid ""
"The Sky Dragon Svarballi is on the move to free himself from his prison; "
"from inside the Sky Soul, he has already taken hold over Menon Hekare's "
"mind..."
msgstr ""
"El Dragón del Cielo Svarballi está en movimiento para liberarse de su "
"prisión; desde dentro del Alma del Cielo, ya ha tomado control sobre la "
"mente de Menon Hekare..."

#. [message], speaker=Vappu
#: War_of_the_Jewel/scenarios/16_Burning_Ice.cfg:664
msgid ""
"(angry) You certainly are bold, young man, to come into Hiera'Kyria with a "
"Maat'Karian banner in hands, ask us to aid that city and, on top of all "
"that, utter that man's name inside our walls!"
msgstr ""
"(enojada) Ciertamente eres audaz, joven, al venir a Hiera'Kyria con un "
"estandarte maat'kariano en las manos, pedirnos que ayudemos a esa ciudad y, "
"encima de todo, pronunciar el nombre de ese hombre dentro de nuestros muros."

#. [message], speaker=Akhen
#: War_of_the_Jewel/scenarios/16_Burning_Ice.cfg:668
msgid ""
"(impatient) You can say whatever you want of me, but you cannot - you must "
"not - turn a blind eye to this danger! The Sky Dragon controls Menon, who "
"right now is the absolute ruler of Maat'Kare, and bent on retrieving the "
"Ruby of Fire, the gem crafted by Ayraton from the Sky Soul! I know you can "
"see where this is going, can't you? If Master Menon takes hold of both the "
"Sky Soul and the Ruby of Fire, with the Sky Dragon's malice controlling him, "
"there's nothing on this world that'll be capable of stopping him!"
msgstr ""
"(impaciente) Puedes decir lo que quieras de mí, pero no puedes, no debes "
"hacer la vista gorda ante este peligro. El Dragón del Cielo controla a "
"Menon, quien ahora es el gobernante absoluto de Maat'Kare y está empeñado en "
"recuperar el Rubí de Fuego, la gema creada por Ayraton a partir del Alma del "
"Cielo. Sé que puedes ver hacia dónde va esto, ¿verdad? Si el maestro Menon "
"toma posesión tanto del Alma del Cielo como del Rubí de Fuego, con la "
"malicia del Dragón del Cielo controlándolo, ¡no habrá nada en este mundo "
"capaz de detenerlo!"

#. [message], speaker=Vappu
#: War_of_the_Jewel/scenarios/16_Burning_Ice.cfg:672
msgid ""
"So that's what you want our aid for: to stop Menon Hekare from taking over "
"the world. I have to admit that the idea of toppling that man is quite "
"tempting, but, young man, tell me..."
msgstr ""
"Así que eso es lo que quieres de nuestra ayuda: detener a Menon Hekare para "
"que no se apodere del mundo. Tengo que admitir que la idea de derrocar a ese "
"hombre es bastante tentadora, pero, joven, dime..."

#. [message], speaker=Vappu
#: War_of_the_Jewel/scenarios/16_Burning_Ice.cfg:679
msgid ""
"...Hasn't it occurred to you that we may have <i>already</i> foreseen that "
"Menon would be corrupted by the Soul, and <i>already</i> taken our measures "
"against the catastrophe you predict?"
msgstr ""
"...¿No se te ha ocurrido que nosotras <i>ya</i> podríamos haber previsto que "
"Menon sería corrompido por el Alma, y <i>ya</i> haber tomado nuestras "
"medidas contra la catástrofe que predices?"

#. [message], speaker=Akhen
#: War_of_the_Jewel/scenarios/16_Burning_Ice.cfg:683
msgid "What do you..."
msgstr "¿Qué quieres decir...?"

#. [message], speaker=Vappu
#: War_of_the_Jewel/scenarios/16_Burning_Ice.cfg:687
msgid ""
"See, Maat'Karian, there are reasons for which we Windsong chose to live in "
"this most inhospitable land: not only does this weather protect us from most "
"foes, but the North Pole is - together with the South Pole - the place where "
"we may access the same power that allowed the Water Dragon, Maat and Myra to "
"defeat Svarballi."
msgstr ""
"Verás, maat'kariano, hay razones por las que nosotras las Hijas del Viento "
"elegimos vivir en esta tierra tan inhóspita: no solo este clima nos protege "
"de la mayoría de los enemigos, sino que el Polo Norte es, junto con el Polo "
"Sur, el lugar donde podemos acceder al mismo poder que permitió al Dragón de "
"Agua, a Maat y a Myra derrotar a Svarballi."

#. [message], speaker=Merwe
#: War_of_the_Jewel/scenarios/16_Burning_Ice.cfg:691
msgid "W-what... Are you saying that..."
msgstr "¿Q-qué... Estás diciendo que...?"

#. [message], speaker=Vappu
#: War_of_the_Jewel/scenarios/16_Burning_Ice.cfg:695
msgid ""
"You're mages, so you must have learned about the currents that impregnate "
"our world: the currents of the air, of the earth... Haven't you ever "
"wondered where these currents converge? (smiling) Yes, young ones, Irdya's "
"currents of magic both sprout and flow into the poles. This means, among "
"other things, that this region bursts with magic energy; another and a much "
"less obvious one is that it allows the best-versed elemental mages to "
"contact the spirits of Nature: the very soul of Irdya."
msgstr ""
"Ustedes son magos, así que deben haber aprendido sobre las corrientes que "
"impregnan nuestro mundo: las corrientes del aire, de la tierra... ¿Nunca se "
"han preguntado dónde convergen estas corrientes? (sonriendo) Sí, jóvenes, "
"las corrientes mágicas de Irdya brotan y fluyen hacia los polos. Esto "
"significa, entre otras cosas, que esta región rebosa de energía mágica; "
"otra, y mucho menos obvia, es que permite a los magos elementales más "
"versados contactar con los espíritus de la Naturaleza: el alma misma de "
"Irdya."

#. [message], speaker=Akhen
#: War_of_the_Jewel/scenarios/16_Burning_Ice.cfg:699
msgid "So, you..."
msgstr "Entonces, ustedes..."

#. [message], speaker=Vappu
#: War_of_the_Jewel/scenarios/16_Burning_Ice.cfg:703
msgid ""
"Yes, we've managed to find - and not easily - a way to reach the spirits: we "
"built an engine that enables us to communicate with the spirits as if with "
"another person. Not only that, but it is also capable of channelling an "
"unprecedented amount of energy into a single focused beam. To put it in "
"mundane terms, it's a magic cannon capable of harnessing the power of Irdya "
"itself."
msgstr ""
"Sí, logramos encontrar, y no fácilmente, una forma de llegar a los "
"espíritus: construimos un artefacto que nos permite comunicarnos con los "
"espíritus como si fueran otra persona. No solo eso, sino que también es "
"capaz de canalizar una cantidad de energía sin precedentes en un solo rayo "
"concentrado. En términos mundanos, es un cañón mágico capaz de aprovechar el "
"poder de Irdya misma."

#. [message], speaker=Vappu
#: War_of_the_Jewel/scenarios/16_Burning_Ice.cfg:712
msgid ""
"Now, young Maat'Karians, do you understand why we don't need to aid you in "
"your fight against Menon and the Sky Dragon? Just let them come here to "
"Hiera'Kyria; we have the means to destroy them and any army they may bring "
"along."
msgstr ""
"Ahora, jóvenes maat'karianos, ¿entienden por qué no necesitamos ayudarlos en "
"su lucha contra Menon y el Dragón del Cielo? Solo déjenlos venir aquí a "
"Hiera'Kyria; tenemos los medios para destruirlos a ellos y a cualquier "
"ejército que puedan traer."

#. [message], speaker=Akhen
#: War_of_the_Jewel/scenarios/16_Burning_Ice.cfg:716
msgid "B-but..."
msgstr "P-pero..."

#. [message], speaker=Vappu
#: War_of_the_Jewel/scenarios/16_Burning_Ice.cfg:723
msgid ""
"You have your answer already, young man: the Windsong shall not go to "
"Maat'Kare's aid. After all... We may no longer return to Netjer-Ta."
msgstr ""
"Ya tienes tu respuesta, joven: las Hijas del Viento no irán en ayuda de "
"Maat'Kare. Después de todo... Ya no podemos regresar a Netjer-Ta."

#. [message], speaker=Akhen
#: War_of_the_Jewel/scenarios/16_Burning_Ice.cfg:727
msgid ""
"I see... You're going to risk having the Sky Dragon destroy all of Irdya "
"because of an ancient grudge..."
msgstr ""
"Ya veo... Van a arriesgarse a que el Dragón del Cielo destruya toda Irdya "
"por un rencor antiguo..."

#. [message], speaker=Akhen
#: War_of_the_Jewel/scenarios/16_Burning_Ice.cfg:731
msgid ""
"...But know one thing, Windsong: you overestimate your own knowledge. There "
"are things about this world, laws ruling its workings, that you ignore, and "
"this may ultimately prove to be your downfall!"
msgstr ""
"...Pero sepan una cosa, Hijas del Viento: sobreestiman su propio "
"conocimiento. Hay cosas sobre este mundo, leyes que rigen su funcionamiento, "
"que ignoran, y eso podría terminar siendo su perdición."

#. [message], speaker=Vappu
#: War_of_the_Jewel/scenarios/16_Burning_Ice.cfg:735
msgid ""
"(coldly) Is that all that you have to say? Fine, then; in acknowledgement "
"for your aid in repelling the Aragwaithi, which reduced the loss of Windsong "
"lives, I shall allow you to go unscathed, but now begone from our sights and "
"our Foundation - and record this in your scrolls: if our scouts sight any "
"Maat'Karian banner ever again, its bearers shall be smitten on the spot!"
msgstr ""
"(fríamente) ¿Eso es todo lo que tienes que decir? Bien, entonces; en "
"reconocimiento por su ayuda al repeler a los aragwaithi, que redujo la "
"pérdida de vidas de las Hijas del Viento, les permitiré irse ilesos, pero "
"ahora desaparezcan de nuestra vista y de nuestra Fundación, y anótenlo en "
"sus pergaminos: si nuestros exploradores vuelven a avistar cualquier "
"estandarte maat'kariano, sus portadores serán abatidos en el acto."

#. [message], speaker=Nyx
#: War_of_the_Jewel/scenarios/16_Burning_Ice.cfg:739
msgid ""
"Let's go, Akhen, there's nothing else we can do now... Let's go before we "
"earn Maat'Kare another dreadful enemy..."
msgstr ""
"Vámonos, Akhen, ya no hay nada más que podamos hacer... Vámonos antes de que "
"le ganemos a Maat'Kare otro enemigo terrible..."

#. [message], speaker=Yukia
#: War_of_the_Jewel/scenarios/16_Burning_Ice.cfg:801
msgid "Hey, Akhen..."
msgstr "Oye, Akhen..."

#. [message], speaker=Merwe
#: War_of_the_Jewel/scenarios/16_Burning_Ice.cfg:805
msgid "Girl, if you're here to say farewell..."
msgstr "Niña, si estás aquí para despedirte..."

#. [message], speaker=Yukia
#: War_of_the_Jewel/scenarios/16_Burning_Ice.cfg:809
msgid ""
"No, I mean, that too, but most importantly, I wish be of some aid to you, in "
"gratitude for how you saved me from the yetis."
msgstr ""
"No, quiero decir, eso también, pero lo más importante es que deseo ser de "
"alguna ayuda para ustedes, en gratitud por cómo me salvaron de los yetis."

#. [message], speaker=Akhen
#: War_of_the_Jewel/scenarios/16_Burning_Ice.cfg:813
msgid ""
"Thanks, Yukia, but a single novice Windsong won't be much of reinforcement "
"for us..."
msgstr ""
"Gracias, Yukia, pero una sola novata de las Hijas del Viento no será un gran "
"refuerzo para nosotros..."

#. [message], speaker=Nyx
#: War_of_the_Jewel/scenarios/16_Burning_Ice.cfg:817
msgid ""
"(calmly) Akhen, there's no need to vent your anger in her, she only wants to "
"help!"
msgstr ""
"(con calma) Akhen, no hace falta que desahogues tu enojo con ella, ¡solo "
"quiere ayudar!"

#. [message], speaker=Yukia
#: War_of_the_Jewel/scenarios/16_Burning_Ice.cfg:821
msgid ""
"No, it's fine, he's right after all... But the aid I want to give you is "
"knowledge; knowledge of possible allies for your cause."
msgstr ""
"No, está bien, después de todo tiene razón... Pero la ayuda que quiero "
"darles es conocimiento; conocimiento de posibles aliados para su causa."

#. [message], speaker=Akhen
#: War_of_the_Jewel/scenarios/16_Burning_Ice.cfg:825
msgid "(surprised) What do you mean?"
msgstr "(sorprendido) ¿Qué quieres decir?"

#. [message], speaker=Yukia
#: War_of_the_Jewel/scenarios/16_Burning_Ice.cfg:829
msgid ""
"Do you Maat'Karians know of an island that is very lush and green, and which "
"floats in the middle of the ocean to the east of Netjer-Ta?"
msgstr ""
"¿Ustedes los maat'karianos conocen una isla muy exuberante y verde que flota "
"en medio del océano al este de Netjer-Ta?"

#. [message], speaker=Mahyus
#: War_of_the_Jewel/scenarios/16_Burning_Ice.cfg:833
msgid "We don't; our people are not very seafaring, you know."
msgstr "No la conocemos; nuestra gente no es muy marinera, sabes."

#. [message], speaker=Yukia
#: War_of_the_Jewel/scenarios/16_Burning_Ice.cfg:837
msgid ""
"Look at this map; this (points at certain place) is the island I talk about. "
"Its inhabitants call it the 'Green Isle', and, though they're not great "
"warriors and have no knowledge of magic, they have contact with nations of a "
"continent further to the south, nations that have mighty warriors and - if "
"the tales are true - even giants."
msgstr ""
"Miren este mapa; esta (señala un lugar) es la isla de la que hablo. Sus "
"habitantes la llaman la «Isla Verde», y aunque no son grandes guerreros y no "
"tienen conocimiento de la magia, tienen contacto con naciones de un "
"continente más al sur, naciones que tienen guerreros poderosos y, si los "
"relatos son ciertos, incluso gigantes."

#. [message], speaker=Merwe
#: War_of_the_Jewel/scenarios/16_Burning_Ice.cfg:841
msgid ""
"Really? Well, that sounds promising - specially if we get these giants to "
"fight for us!"
msgstr ""
"¿De verdad? Bueno, eso suena prometedor, especialmente si logramos que esos "
"gigantes luchen por nosotros."

#. [message], speaker=Yukia
#: War_of_the_Jewel/scenarios/16_Burning_Ice.cfg:845
msgid ""
"You can have this map and... Ah, there's more: beware of the west winds, "
"they may blow your ship off course and towards the island of Morogor, "
"where..."
msgstr ""
"Pueden quedarse con este mapa y... Ah, hay más: tengan cuidado con los "
"vientos del oeste, pueden desviar su barco del rumbo y llevarlo hacia la "
"isla de Morogor, donde..."

#. [message], speaker=Akhen
#: War_of_the_Jewel/scenarios/16_Burning_Ice.cfg:849
msgid ""
"...The dragons and the drakes live, I know. Yukia, thanks very much for the "
"map and the information, you've really given us hope once again. And sorry "
"for getting mad at you..."
msgstr ""
"...viven los dragones y los dracos, lo sé. Yukia, muchas gracias por el mapa "
"y la información, realmente nos has dado esperanza otra vez. Y perdón por "
"enojarme contigo..."

#. [message], speaker=Yukia
#: War_of_the_Jewel/scenarios/16_Burning_Ice.cfg:853
msgid ""
"No probs, really. Now, you better go at once, before Headmistress gets "
"really mad at you; trust me, you don't want to see her really mad."
msgstr ""
"No hay problema, de verdad. Ahora, mejor váyanse de inmediato, antes de que "
"la directora se enoje de verdad con ustedes; créanme, no quieren verla "
"realmente enojada."

#. [message], speaker=Nyx
#: War_of_the_Jewel/scenarios/16_Burning_Ice.cfg:857
msgid ""
"(smiling) And you better watch out where you go, girl; if you get yourself "
"in trouble with yetis again, we won't be there to save you."
msgstr ""
"(sonriendo) Y tú mejor cuídate por dónde andas, niña; si te metes en "
"problemas con yetis otra vez, no estaremos allí para salvarte."

#. [message], speaker=Yukia
#: War_of_the_Jewel/scenarios/16_Burning_Ice.cfg:861
msgid ""
"Farewell, friends, and good luck! Kick the Sky Dragon's scaly ass for us!"
msgstr ""
"¡Adiós, amigos, y buena suerte! ¡Denle una patada en el trasero escamoso al "
"Dragón del Cielo de nuestra parte!"

#. [message], speaker=Akhen
#: War_of_the_Jewel/scenarios/16_Burning_Ice.cfg:906
msgid "Damn it, how could we let her die?"
msgstr "¡Maldición, cómo pudimos dejarla morir!"

#. [message], speaker=Vappu
#: War_of_the_Jewel/scenarios/16_Burning_Ice.cfg:920
msgid "I... fall...?!"
msgstr "¡Yo... caigo...?!"

#. [message], speaker=Akhen
#: War_of_the_Jewel/scenarios/16_Burning_Ice.cfg:924
msgid ""
"No! Without their leader, there's no way the Windsong will accept helping us!"
msgstr ""
"¡No! ¡Sin su líder, no hay forma de que las Hijas del Viento acepten "
"ayudarnos!"

#. [message], speaker=Kalinyon
#: War_of_the_Jewel/scenarios/16_Burning_Ice.cfg:935
msgid ""
"Damn these cursed Windsong and those even more cursed strangers! I didn't "
"want to sacrifice even more Aragwaithi lives in this campaign, but I have no "
"choice now: call in all the reserves!"
msgstr ""
"¡Malditas sean estas Hijas del Viento malditas y esos extraños aún más "
"malditos! No quería sacrificar aún más vidas aragwaithi en esta campaña, "
"pero ahora no tengo opción: ¡llamen a todas las reservas!"

#. [message], speaker=Vappu
#: War_of_the_Jewel/scenarios/16_Burning_Ice.cfg:939
msgid ""
"Oh no... Damn it, there's no way we can defeat such a horde! Hiera'Kyria is "
"doomed!"
msgstr ""
"Oh no... Maldición, ¡no hay forma de que podamos derrotar a semejante horda! "
"¡Hiera'Kyria está condenada!"

#. [scenario], id=17_Flora_Island
#: War_of_the_Jewel/scenarios/17_Flora_Island.cfg:4
msgid "Flora's Island"
msgstr "Isla de Flora"

#. [objective], condition=win
#: War_of_the_Jewel/scenarios/17_Flora_Island.cfg:25
#: War_of_the_Jewel/scenarios/17_Flora_Island.cfg:540
#: War_of_the_Jewel/scenarios/17_Flora_Island.cfg:691
msgid "Find the town of Rockvale"
msgstr "Encuentra la ciudad de Rockvale"

#. [objective], condition=lose
#: War_of_the_Jewel/scenarios/17_Flora_Island.cfg:37
#: War_of_the_Jewel/scenarios/17_Flora_Island.cfg:556
#: War_of_the_Jewel/scenarios/17_Flora_Island.cfg:703
#: War_of_the_Jewel/scenarios/17_Flora_Island.cfg:876
#: War_of_the_Jewel/scenarios/18_Rekindled_Fire.cfg:34
#: War_of_the_Jewel/scenarios/18_Rekindled_Fire.cfg:373
#: War_of_the_Jewel/scenarios/19_Stone_Of_Destiny.cfg:42
#: War_of_the_Jewel/scenarios/20_Ancient_Fire.cfg:44
#: War_of_the_Jewel/scenarios/20_Ancient_Fire.cfg:426
#: War_of_the_Jewel/scenarios/20_Ancient_Fire.cfg:504
#: War_of_the_Jewel/scenarios/20_Ancient_Fire.cfg:675
#: War_of_the_Jewel/scenarios/20_Ancient_Fire.cfg:944
#: War_of_the_Jewel/scenarios/21_The_Windy_Plains.cfg:47
