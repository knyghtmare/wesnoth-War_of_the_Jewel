msgstr "fuego nocturno"

#. [advancement], id=shadowdancer
#: War_of_the_Jewel/utils/character-utils.cfg:594
msgid "Nyx remains invisible to enemies while in the dark"
msgstr ""
"Nyx permanece invisible para los enemigos mientras está en la oscuridad"

#. [hides], id=nightstalk
#: War_of_the_Jewel/utils/character-utils.cfg:603
#: War_of_the_Jewel/utils/character-utils.cfg:604
#: War_of_the_Jewel/utils/character-utils.cfg:608
