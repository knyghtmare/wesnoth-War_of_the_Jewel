#: War_of_the_Jewel/scenarios/03_Between_The_Mountains_And_The_Wood.cfg:26
#: War_of_the_Jewel/scenarios/03_Between_The_Mountains_And_The_Wood.cfg:470
#: War_of_the_Jewel/scenarios/03_Between_The_Mountains_And_The_Wood.cfg:591
msgid "Defeat the Orcish vanguard"
msgstr "Derrota a la vanguardia orca"

#. [objective], condition=win
#: War_of_the_Jewel/scenarios/03_Between_The_Mountains_And_The_Wood.cfg:31
#: War_of_the_Jewel/scenarios/03_Between_The_Mountains_And_The_Wood.cfg:475
msgid "Move Sigdral to the island to get the fairies to aid you."
msgstr "Mueve a Sigdral a la isla para que las hadas te ayuden."

