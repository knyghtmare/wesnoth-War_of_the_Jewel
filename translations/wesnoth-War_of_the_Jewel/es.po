msgstr "Nyx drena más sangre de las víctimas"

#. [advancement], id=sword_dancer
#: War_of_the_Jewel/utils/character-utils.cfg:660
msgid "Nyx's sword blows are faster"
msgstr "Los golpes de espada de Nyx son más rápidos"

#. [advancement], id=nighthell
#: War_of_the_Jewel/utils/character-utils.cfg:683
